# ─── Server ───────────────────────────────────────────
PORT=3000
ADMIN_PASSWORD=choose_a_strong_password

# ─── Database (Railway provides this automatically) ───
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Purelymail / SMTP ────────────────────────────────
SMTP_HOST=mail.purelymail.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.com
SMTP_PASS=your_email_password
NOTIFICATION_EMAIL=you@yourdomain.com

# ─── Twilio ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBER=+17738491854

# ─── HubSpot ──────────────────────────────────────────
# Settings → Integrations → Private Apps → Create app
# Scopes: crm.objects.contacts.read, crm.objects.contacts.write,
#         crm.objects.deals.write, timeline
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Clover ───────────────────────────────────────────
CLOVER_API_TOKEN=your_clover_api_token
CLOVER_MERCHANT_ID=your_16_char_merchant_id
CLOVER_APP_ID=your_app_id
CLOVER_APP_SECRET=your_app_secret
